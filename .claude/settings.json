{
  "permissions": {
    "allow": [
      "Read",
      "LS",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(ruff check:*)",
      "Bash(ruff format:*)",
      "Bash(mypy:*)"
    ],
    "ask": [
      "Bash(pip install:*)",
      "Bash(poetry add:*)",
      "Bash(uv add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(curl * | sh:*)",
      "Bash(wget * | sh:*)",
      "Bash(*.env*)",
      "Bash(printenv:*)"
    ]
  }
}
